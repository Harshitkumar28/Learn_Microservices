package com.learnms.accounts.repository;

import com.learnms.accounts.entity.Customer;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.stereotype.Repository;

import java.util.Optional;

@Repository
public interface CustomerRepository extends JpaRepository<Customer, Long> {
    Optional<Customer> findByMobileNumber(String mobileNumber);
    // This concept is called "Derived-Name Method'
    // this findBy is important to find the customer by mobile number (it is user generated field)
    // above is case-insensitive

}
